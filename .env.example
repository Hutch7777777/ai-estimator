# Public browser configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key
NEXT_PUBLIC_ENABLE_PUBLIC_SIGNUP=false

# Server-only extraction service configuration
EXTRACTION_API_URL=https://your-extraction-service.example.com
EXTRACTION_API_KEY=replace_with_a_long_random_value
EXTRACTION_API_SIGNING_SECRET=replace_with_a_different_long_random_value

# Server-only workflow configuration
N8N_WEBHOOK_URL=https://your-n8n-host.example.com/webhook
N8N_WEBHOOK_SECRET=replace_with_a_long_random_value

# Optional server-side providers used by specific routes
ANTHROPIC_API_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
REPLICATE_API_TOKEN=
ROBOFLOW_API_KEY=
ROBOFLOW_INFERENCE_URL=
ROBOFLOW_WORKFLOW_URL=
